from src.shelby_client import ShelbyClient, ShelbyDataset
from src.utils import get_dataloader
import torch.nn as nn
import torch.optim as optim

# Config (thay bằng thực)
ENDPOINT = 'https://testnet.shelby.xyz'
ACCESS_KEY = 'YOUR_ACCESS_KEY'
SECRET_KEY = 'YOUR_SECRET_KEY'
BUCKET = 'my-ai-bucket'
OBJECT_KEY = 'dataset.csv'

client = ShelbyClient(ENDPOINT, ACCESS_KEY, SECRET_KEY)
client.set_bucket(BUCKET)

# Upload example (comment if already uploaded)
# client.upload_file('path/to/local_dataset.csv', OBJECT_KEY)

# Stream to Dataset
dataset = ShelbyDataset(client, OBJECT_KEY)
dataloader = get_dataloader(dataset, batch_size=64)

# Simple model (customize)
model = nn.Linear(10, 1)  # Assume input size 10
optimizer = optim.SGD(model.parameters(), lr=0.01)
loss_fn = nn.MSELoss()

# Train loop (demo)
for epoch in range(5):
    for batch in dataloader:
        inputs = batch[:, :-1]  # Assume last col is label
        labels = batch[:, -1].unsqueeze(1)
        outputs = model(inputs)
        loss = loss_fn(outputs, labels)
        optimizer.zero_grad()
        loss.backward()
        optimizer.step()
    print(f"Epoch {epoch}: Loss {loss.item()}")

# Verify
client.verify_proof('EXAMPLE_OBJECT_ID')  # Thay bằng real ID
